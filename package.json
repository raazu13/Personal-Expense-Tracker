{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\" --names \"Flask,Vite\" --prefix-colors \"blue,green\"",
    "backend": "cd backend && python app.py",
    "frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
